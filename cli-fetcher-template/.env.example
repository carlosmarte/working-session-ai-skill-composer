# GitHub authentication (required for private repos, optional for public)
GITHUB_TOKEN=

# GitHub Enterprise: override the API base URL
# GITHUB_API_URL=https://github.example.com/api/v3

# Pre-fill prompts via env (all optional — CLI flags take priority)
SKILL_FETCHER_REPO=
SKILL_FETCHER_BRANCH=
SKILL_FETCHER_OUTPUT=

# Default data source file for template rendering (optional)
SKILL_FETCHER_DATA=
